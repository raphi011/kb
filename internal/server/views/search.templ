package views

import (
	"github.com/raphi011/kb/internal/index"
)

templ SearchResults(notes []index.Note) {
	<ul class="search-results" role="list">
		for _, note := range notes {
			<li>
				@ContentLink("result-item", "/notes/" + note.Path) {
					<div class="result-title">{ note.Title }</div>
				}
			</li>
		}
	</ul>
}

templ SearchEmpty() {
	<div class="sidebar-empty">No results</div>
}
